# 한국투자증권 Open API 기본 설정 예시
# KIS_ENV=prod  -> 실계좌 키/계좌 세트 사용
# KIS_ENV=vps   -> 모의투자 키/계좌 세트 사용

KIS_ENV=vps

# 실계좌 세트
KIS_PROD_ACCOUNT_NO=
KIS_PROD_ACCOUNT_PRODUCT_CODE=
KIS_PROD_HTS_ID=

# 모의투자 세트
KIS_VPS_ACCOUNT_NO=
KIS_VPS_ACCOUNT_PRODUCT_CODE=
KIS_VPS_HTS_ID=

# 선택: 파일 대신 환경변수로 직접 넣고 싶을 때만 사용
KIS_PROD_APPKEY=
KIS_PROD_APPSECRET=
KIS_VPS_APPKEY=
KIS_VPS_APPSECRET=

# 안전장치
# DRY_RUN=true  -> 주문 제출 차단, preview만 허용
# DRY_RUN=false -> order-test --execute 허용
# LIVE_TRADING_ENABLED=true 는 실계좌(prod)에서만 의미가 있습니다.
DRY_RUN=true
LIVE_TRADING_ENABLED=false

# 텔레그램은 kinvest_trade/keys 가 비어 있어도
# 기본적으로 ~/kiwoom_trade/keys 값을 fallback 으로 읽도록 구성했습니다.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
